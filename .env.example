# Backend API — required. Browser streams reviews directly to this URL (must include /api).
NEXT_PUBLIC_API_BASE_URL=https://your-backend.onrender.com/api

# Optional legacy BFF proxy (not used for reviews in production)
API_BASE_URL=
NEXT_PUBLIC_APP_URL=

# Backend email (set in code-review-backend/.env)
# EMAIL_USER=
# EMAIL_PASS=
